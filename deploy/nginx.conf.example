# SPA (React Router): sirve archivos estáticos y cae a index.html en rutas del cliente.
# Copia/adapta en tu server block de nginx.

server {
    listen 80;
    server_name deposito.example.com;

    root /var/www/deposito-frontend/dist;
    index index.html;

    # Assets con hash (Vite) — cache largo
    location /assets/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /icons/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=86400";
    }

    # API: proxy al backend (ajusta host/puerto)
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Todas las rutas del frontend (/q/:token, /cotizaciones, etc.)
    location / {
        try_files $uri $uri/ /index.html;
    }
}
